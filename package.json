{
  "name": "fshare",
  "version": "2.0.0",
  "description": "File Sharing Web App",
  "type": "module",
  "main": "server/index.js",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev:server": "node --env-file=.env --watch server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "migrate": "knex migrate:latest --knexfile server/db/knexfile.js",
    "start": "npm run migrate && node --env-file-if-exists=.env server/index.js",
    "test": "node --env-file=.env.test --test-concurrency=1 --test 'server/test/**/*.test.js'"
  },
  "author": "Arnab Biswas",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "knex": "^3.1.0",
    "multer": "^2.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.1.0",
    "supertest": "^7.0.0"
  }
}
